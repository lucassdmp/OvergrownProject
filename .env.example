# Copy this file to .env.local and fill in the Web App values shown in
# Firebase Console > Project settings > Your apps > SDK setup and configuration.
# Firebase Web configuration is public; access is protected by Firebase Rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firestore document used as the shared room/tree. Deployments with the same ID
# collaborate on the same tree. Change it to create an independent tree.
VITE_FIREBASE_TREE_ID=official
